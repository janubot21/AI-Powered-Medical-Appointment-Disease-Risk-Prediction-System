# CSV path overrides (optional)
# You can keep these relative to project root or use absolute paths.
# Copy this file to .env and replace the placeholder values before running locally.
# Set OPENAI_API_KEY to enable the patient AI chat with OpenAI.
# Model defaults to gpt-4o-mini if OPENAI_CHAT_MODEL is omitted.

NEW_PATIENT_CSV_PATH=datasets/new_patient_data.csv
PATIENTS_CSV_PATH=datasets/patients.csv
DOCTOR_ACCOUNTS_CSV_PATH=datasets/doctor_accounts.csv
PATIENT_ACCOUNTS_CSV_PATH=datasets/patient_accounts.csv
NURSE_ACCOUNTS_CSV_PATH=datasets/nurse_accounts.csv
DOCTOR_LEAVE_CSV_PATH=datasets/doctor_leave.csv
DOCTOR_PROFILE_CSV_PATH=datasets/doctor_profiles.csv
PATIENT_DB_PATH=datasets/patient_records.db
FLASK_SECRET_KEY=replace-with-a-long-random-secret
COOKIE_SECURE=0
OPENAI_API_KEY=your-openai-api-key
OPENAI_CHAT_MODEL=gpt-4o-mini
